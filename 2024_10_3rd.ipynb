   "source": [
    "from itertools import combinations\n",
    "\n",
    "def solution(numbers):\n",
    "    \n",
    "    answer = []\n",
    "    for x, y in combinations(numbers, 2):\n",
    "        answer.append(x+y)\n",
    "    \n",
    "    return sorted(list(set(answer)))"
   ]
  }
